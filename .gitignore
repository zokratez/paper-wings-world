# This .gitignore is adapted for a Unity + geospatial project (Cesium/Mapbox possible later)
# Standard Unity
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# Asset Store tools
[Aa]ssets/AssetStoreTools*

# Autogenerated
[Aa]ssets/[Aa]ssetStoreTools*

# Visual Studio / Rider
.vs/
.idea/
*.sln
*.csproj
*.user
*.suo

# Mac
.DS_Store

# Cesium / 3D Tiles (if we add later)
[Aa]ssets/Cesium*
[Aa]ssets/Editor/Cesium*

# Mapbox (if used)
[Aa]ssets/Mapbox*
[Aa]ssets/Editor/Mapbox*

# Large binary assets we want to LFS or avoid
*.psd
*.fbx
*.blend1

# Build output
*.apk
*.aab
*.ipa
*.app

# Unity generated
[Aa]ssets/StreamingAssets/aa/*
[Aa]ssets/StreamingAssets/aa.meta

# Notes are intentionally tracked (they are the source of truth in Phase 0)
# /notes/ is committed

# Ignore Unity package cache if you want (sometimes useful to keep)
# Packages/packages-lock.json

# Keep the lock file for reproducibility in later phases
!Packages/packages-lock.json

# Personal
*.log
*.tmp